<div class="row justify-content-center">

    <div class="col-md-7">

        <div class="card border-0 shadow-sm">

            <div class="card-body p-4">

                <h3 class="fw-bold mb-4">
                    Edit Contact
                </h3>

                <% if (error) { %>

                    <div class="alert alert-danger">

                        <%= error %>

                    </div>

                <% } %>

                <form
                    action="/contacts/edit/<%= contact._id %>"
                    method="POST">

                    <div class="mb-3">

                        <label class="form-label">
                            Full Name
                        </label>

                        <input
                            type="text"
                            name="fullname"
                            class="form-control"
                            value="<%= contact.fullname %>">

                    </div>

                    <div class="mb-3">

                        <label class="form-label">
                            Phone Number
                        </label>

                        <input
                            type="text"
                            name="phone"
                            class="form-control"
                            value="<%= contact.phone %>">

                    </div>

                    <div class="mb-3">

                        <label class="form-label">
                            Email
                        </label>

                        <input
                            type="email"
                            name="email"
                            class="form-control"
                            value="<%= contact.email %>">

                    </div>

                    <div class="mb-4">

                        <label class="form-label">
                            Address
                        </label>

                        <textarea
                            name="address"
                            rows="3"
                            class="form-control"><%= contact.address %></textarea>

                    </div>

                    <button class="btn btn-warning">

                        Update Contact

                    </button>

                </form>

            </div>

        </div>

    </div>

</div>